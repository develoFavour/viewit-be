{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "types": ["node"],
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": "./",
    "ignoreDeprecations": "6.0"
  },
  "include": ["prisma.config.ts"],
  "exclude": ["node_modules", "src", "dist"]
}
